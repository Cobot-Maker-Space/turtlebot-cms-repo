{
  "name": "my-devcontainer-image:latest",
  "image": "my-devcontainer-image:latest",
  "privileged": true,
  "remoteUser": "user",
  "updateRemoteUserUID": false,
  
  
  "workspaceFolder": "/home/ros2_ws",
  "workspaceMount": "source=${localWorkspaceFolder},target=/home/ros2_ws/src,type=bind",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-vscode.cpptools",
        "ms-vscode.cpptools-themes",
        "twxs.cmake",
        "donjayamanne.python-extension-pack",
        "eamodio.gitlens",
        "ms-iot.vscode-ros"
      ]
    }
  },
  "containerEnv": {
    "DISPLAY": "novnc:0.0",
    "ROS_LOCALHOST_ONLY": "0",
    "ROS_DOMAIN_ID": "30",
    "RMW_IMPLEMENTATION": "rmw_fastrtps_cpp",
    "TURTLEBOT3_MODEL": "waffle"
  },
  // Keep runArgs minimal for cross-platform compatibility.
  // Add Linux-only device access or network flags manually if needed.
  "forwardPorts": [8080],
  "mounts": [
    "source=${localWorkspaceFolder}/../cache/humble/build,target=/home/ros2_ws/build,type=bind",
    "source=${localWorkspaceFolder}/../cache/humble/install,target=/home/ros2_ws/install,type=bind",
    "source=${localWorkspaceFolder}/../cache/humble/log,target=/home/ros2_ws/log,type=bind"
  ],
  "postCreateCommand": "bash /usr/local/bin/setup.sh"
}
